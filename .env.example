# Facebook API přístupové údaje
FACEBOOK_APP_ID=your_app_id
FACEBOOK_APP_SECRET=your_app_secret
FACEBOOK_ACCESS_TOKEN=your_access_token
FACEBOOK_ACCOUNT_ID=your_ad_account_id

# Volitelné – stránka a business (fallback, když nejsou v tokens.json)
FACEBOOK_PAGE_ID=your_page_id
FACEBOOK_PAGE_ACCESS_TOKEN=your_page_access_token
# Business ID – nutné pro create_offline_conversion_set
FACEBOOK_BUSINESS_ID=your_business_id

# Volitelné – EU DSA (povinné při cílení na EU; kdo z reklamy těží / kdo ji platí)
FB_DSA_BENEFICIARY=Your Company s.r.o.
FB_DSA_PAYOR=Your Company s.r.o.

# Volitelné – přepsání verze Graph API (výchozí v25.0)
# FB_GRAPH_API_VERSION=v25.0

# MCP Server nastavení
PORT=3000
